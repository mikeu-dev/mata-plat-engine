# ============================================
# DATABASE (MySQL)
# ============================================
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=parking_db

# ============================================
# ENGINE
# ============================================
# Port untuk streaming server (Waitress)
STREAM_PORT=5000
ENABLE_WINDOW=False

# Tarif parkir default per jam (Rupiah)
BIAYA_PER_JAM=5000
HMAC_SECRET=your_secure_hmac_secret_here

# ============================================
# DASHBOARD INTEGRATION
# ============================================
# URL API dashboard.
# Development: http://localhost:5173/api/v1/...
# Production:  https://smartparking.ramahteknologi.com/api/v1/...
DASHBOARD_API_URL=http://localhost:5173/api/v1/event
DASHBOARD_CONFIG_URL=http://localhost:5173/api/v1/config

# Kunci autentikasi. HARUS SAMA dengan INTERNAL_API_KEY di dashboard.
# Generate: openssl rand -hex 24
DASHBOARD_API_KEY=

# ============================================
# APP
# =============================
FLASK_DEBUG=True
STREAM_PORT=5000

# API Key untuk melindungi endpoint engine (digunakan oleh Dashboard)
# Masukkan key ini ke .env dashboard sebagai PUBLIC_ENGINE_API_KEY
# Kunci autentikasi internal. HARUS SAMA dengan PUBLIC_ENGINE_API_KEY di dashboard.
# Generate: openssl rand -hex 24
ENGINE_API_KEY=mata-plat-engine-secret
# Set False di produksi
FLASK_DEBUG=False
DEBUG_MODE=False

# (Opsional) Path ke Python venv, bisa dideteksi otomatis oleh ecosystem.config.js
# PYTHON_PATH=/path/to/venv/bin/python

# AI Acceleration
# Options: auto, cpu, cuda, cuda:0, cuda:1
AI_DEVICE=auto
OCR_USE_GPU=False
